<Window

x:Class="MusicHUD.MainWindow"

xmlns=
"http://schemas.microsoft.com/winfx/2006/xaml/presentation"

xmlns:x=
"http://schemas.microsoft.com/winfx/2006/xaml"


WindowStyle="None"

AllowsTransparency="True"

Background="Transparent"

Topmost="True"

ShowInTaskbar="False"


Width="420"

Height="150">


<Grid>


<Border

CornerRadius="25"

Background="#99000000"

Padding="20">


<StackPanel>


<TextBlock

Text="🎵 Music HUD"

FontSize="26"

Foreground="White"/>



<TextBlock

Name="SongText"

Text="等待音乐..."

FontSize="24"

Foreground="Cyan"/>



<TextBlock

Name="ArtistText"

FontSize="16"

Foreground="White"/>


</StackPanel>


</Border>


</Grid>


</Window>
